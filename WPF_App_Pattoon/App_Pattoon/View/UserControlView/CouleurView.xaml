<UserControl x:Class="Wpf_App_Pattoon_Animalerie.View.UserControlView.CouleurView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf_App_Pattoon_Animalerie.View.UserControlView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="97*"/>
            <RowDefinition Height="284*"/>
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Height="Auto" Width="Auto">
            <TextBlock TextWrapping="Wrap" Text="LES COULEURS"
                       FontSize="20" Foreground="White"/>
            <TextBlock Text="{Binding Message}"
HorizontalAlignment="Center"
VerticalAlignment="Center"
FontSize="16" Height="38" Width="0"/>


        </StackPanel>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
     Height="Auto" Width="Auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="13*"/>
                <ColumnDefinition Width="7*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" ItemsSource="{Binding LesCouleur}" Margin="10,0,10,0"
                     SelectedItem="{Binding CouleurSelectionne}"
                     SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True"
                     AutoGenerateColumns="True" HeadersVisibility="Column" 
                     FontFamily="Lucida Sans" 
                     VerticalContentAlignment="Center" 
                     Background="{x:Null}" 
                     Foreground="#FF3D5E82" 
                     FontSize="14" 
                     IsSynchronizedWithCurrentItem="True"
                     HorizontalGridLinesBrush="#FFADABAB" 
                     VerticalGridLinesBrush="#FF9E9E9E" 
                     AlternatingRowBackground="#FFE6F5FF" 
                      RowBackground="White" 
                    >
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                    Command="{Binding OuvrirDetailCommand}"
                    CommandParameter="{Binding CouleurSelectionne}"/>

                </DataGrid.InputBindings>
            </DataGrid>

            <StackPanel Grid.Column="1">

                <StackPanel>
                    <TextBlock Text="{Binding Id}"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" MinHeight="150" Margin="10">
                    <TextBlock Text="Nom" FontSize="14" Foreground="#FFF4F537"/>
                    <TextBox Text="{Binding Nom}" Width="Auto" MinWidth="150" FontSize="20" Margin="0,5"/>

                </StackPanel>

                <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Height="Auto" Width="Auto">
                    <Button Content="Nouveau"
                         Command="{Binding NouveauCommand}"
                         Width="100"
                         Height="35"
                         Margin="10"/>

                    <Button Content="Enregistrer"
                         Command="{Binding AjouteCommand}"
                         Width="100"
                         Height="35"
                         Margin="10"/>

                    <Button Content="Supprimer"
                         Command="{Binding SupprimerCommand}"
                         Width="100"
                         Height="35"
                         Margin="10"/>
                </StackPanel>

            </StackPanel>

        </Grid>



    </Grid>
</UserControl>
