<UserControl x:Class="Wpf_App_Pattoon_Animalerie.View.UserControlView.ContactView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf_App_Pattoon_Animalerie.View.UserControlView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"  MinHeight="300"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <TextBlock Text="LES CONTACTS" Margin="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="30"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding LesContacts}" 
              SelectedItem="{Binding ContactSelectionne}" Margin="10,0"
              SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True"
              AutoGenerateColumns="True" HeadersVisibility="Column" 
              FontFamily="Lucida Sans" 
              VerticalContentAlignment="Center"
              Background="{x:Null}" 
              Foreground="#FF3D5E82" 
              FontSize="14" 
              IsSynchronizedWithCurrentItem="True"
              HorizontalGridLinesBrush="#FFADABAB" 
              VerticalGridLinesBrush="#FF9E9E9E" 
              AlternatingRowBackground="#FFE6F5FF" 
              RowBackground="White" 
              Width="Auto" MinWidth="500">

            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick"
                          Command="{Binding OuvrirDetailCommand}"
                          CommandParameter="{Binding ContactSelectionne}"/>

            </DataGrid.InputBindings>

        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                HorizontalAlignment="Center"
                VerticalAlignment="Center" Height="60">

            <Button Content="Nouveau"
                Command="{Binding NouveauCommand}"
                Width="100"
                Height="35"
                Margin="10"/>

        </StackPanel>

    </Grid>
</UserControl>
