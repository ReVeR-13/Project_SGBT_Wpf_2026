<UserControl x:Class="Wpf_App_Pattoon_Animalerie.View.UserControlView.TypeContactView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf_App_Pattoon_Animalerie.View.UserControlView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="37*"/>

        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Height="66" Width="192">
            <TextBlock TextWrapping="Wrap" 
                       Text="LES TYPES CONTACTS"
                       FontSize="20" Foreground="White"/>
            <TextBlock Text="{Binding Message}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="16" Height="38" Width="0"/>


        </StackPanel>

        <Grid Grid.Row="1" 
              Height="Auto" Width="Auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="101*"/>
                <ColumnDefinition Width="59*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" ItemsSource="{Binding LesTypes}" 
                    SelectedItem="{Binding TypeSelectionne}"
                    SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True"
                    AutoGenerateColumns="True" HeadersVisibility="Column" 
                    FontFamily="Lucida Sans" 
                    VerticalContentAlignment="Center" 
                    Background="{x:Null}" 
                    Foreground="#FF3D5E82" 
                    FontSize="14" 
                    IsSynchronizedWithCurrentItem="True"
                    HorizontalGridLinesBrush="#FFADABAB" 
                    VerticalGridLinesBrush="#FF9E9E9E" 
                    AlternatingRowBackground="#FFE6F5FF" 
                    RowBackground="White" 
                    Width="Auto">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                            Command="{Binding OuvrirDetailCommand}"
                            CommandParameter="{Binding TypeSelectionne}"/>

                </DataGrid.InputBindings>
            </DataGrid>

            <StackPanel Grid.Column="1">

                <StackPanel>
                    <TextBlock Text="{Binding Id}"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" MinHeight="150" Margin="10">
                    <TextBlock Text="Nom" FontSize="14" Foreground="#FFFFDB33"/>
                    <TextBox Text="{Binding Nom}" Width="Auto" MinWidth="150" FontSize="20" Margin="0,5" Background="{x:Null}" Foreground="White"/>

                    <TextBlock Text="Description" FontSize="14" Foreground="#FFFFE00D"/>
                    <RichTextBox Height="100" Padding="10" Background="{x:Null}" Foreground="White">
                        <FlowDocument>
                            <Paragraph>
                                <Run Text="{Binding Description}" FontSize="16"/>
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                </StackPanel>

                <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Height="Auto" Width="Auto">
                    <Button Content="Nouveau"
            Command="{Binding NouveauCommand}"
            Width="100"
            Height="35"
            Margin="10"/>

                    <Button Content="Enregistrer"
            Command="{Binding AjouteCommand}"
            Width="100"
            Height="35"
            Margin="10"/>

                    <Button Content="Supprimer"
            Command="{Binding SupprimerCommand}"
            Width="100"
            Height="35"
            Margin="10"/>
                </StackPanel>

            </StackPanel>

        </Grid>



    </Grid>
</UserControl>
