<UserControl x:Class="Wpf_App_Pattoon_Animalerie.View.UserControlView.MotifEntreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf_App_Pattoon_Animalerie.View.UserControlView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="97*"/>
            <RowDefinition Height="284*"/>
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Height="Auto" Width="Auto">
            <TextBlock TextWrapping="Wrap" Text="LES MOTIFS D'ENTREE"
                       FontSize="20" Foreground="White"/>
            <TextBlock Text="{Binding Message}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 FontSize="16" Height="38" Width="0"/>


        </StackPanel>

        <Grid Grid.Row="1" 
             Height="Auto" Width="Auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="13*"/>
                <ColumnDefinition Width="7*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" ItemsSource="{Binding LesMotifs}" 
                 SelectedItem="{Binding MotifSelectionne}" Margin="10,0,10,0"
                 SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True"
                 AutoGenerateColumns="True" HeadersVisibility="Column" 
                 FontFamily="Lucida Sans" 
                 VerticalContentAlignment="Center" 
                  Background="{x:Null}" 
                 Foreground="#FF3D5E82" 
                 FontSize="14" 
                 IsSynchronizedWithCurrentItem="True"
                 HorizontalGridLinesBrush="#FFADABAB" 
                 VerticalGridLinesBrush="#FF9E9E9E" 
                 AlternatingRowBackground="#FFE6F5FF" 
                 RowBackground="White" 
                 Width="Auto">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding OuvrirDetailCommand}"
                                  CommandParameter="{Binding MotifSelectionne}"/>

                </DataGrid.InputBindings>
            </DataGrid>

            <StackPanel Grid.Column="1">

                <StackPanel>
                    <TextBlock Text="{Binding Id}"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" MinHeight="150" Margin="10">
                    <TextBlock Text="Nom" FontSize="14" Foreground="#FFD5FD2D"/>
                    <TextBox Text="{Binding Nom}" Width="Auto" MinWidth="150" FontSize="20" Margin="0,5"/>

                    <TextBlock Text="Description" FontSize="14" Foreground="#FFD5FD2D"/>
                    <RichTextBox Height="100" Margin="0,5">
                        <FlowDocument>
                            <Paragraph>
                                <Run Text="{Binding Description}" FontSize="20"/>
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                </StackPanel>

                <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Height="Auto" Width="Auto">
                    <Button Content="Nouveau"
         Command="{Binding NouveauCommand}"
         Width="100"
         Height="35"
         Margin="10"/>

                    <Button Content="Enregistrer"
         Command="{Binding AjouteCommand}"
         Width="100"
         Height="35"
         Margin="10"/>

                    <Button Content="Supprimer"
         Command="{Binding SupprimerCommand}"
         Width="100"
         Height="35"
         Margin="10"/>
                </StackPanel>

            </StackPanel>

        </Grid>



    </Grid>
</UserControl>
