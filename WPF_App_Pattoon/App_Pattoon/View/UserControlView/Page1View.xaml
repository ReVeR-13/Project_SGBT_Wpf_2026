<UserControl x:Class="Wpf_App_Pattoon_Animalerie.View.UserControlView.Page1View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf_App_Pattoon_Animalerie.View.UserControlView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#FF1A687D" Margin="0,0,-85,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="97*"/>
            <RowDefinition Height="284*"/>
            <RowDefinition Height="69*"/>
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Height="Auto" Width="Auto">

            <TextBlock Text="{Binding Message}"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           FontSize="16" Height="38" Width="0"/>

        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Orientation="Horizontal"
                MinHeight="250" MinWidth="500" Height="Auto" Width="Auto">

            <DataGrid ItemsSource="{Binding LesAbris}" 
                  SelectedItem="{Binding AbriSelectionne}" Margin="10,0"
                  SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True"
                  AutoGenerateColumns="True" HeadersVisibility="Column" 
                  FontFamily="Lucida Sans" 
                  VerticalContentAlignment="Center" 
                  Background="{x:Null}" 
                  Foreground="#FF3D5E82" 
                  FontSize="14" 
                  IsSynchronizedWithCurrentItem="True"
                  HorizontalGridLinesBrush="#FFADABAB" 
                  VerticalGridLinesBrush="#FF9E9E9E" 
                  AlternatingRowBackground="#FFE6F5FF" 
                  RowBackground="White" 
                  Width="Auto" MinWidth="500"/>

            <StackPanel Height="264" Width="350" Margin="10,0">

                <StackPanel>
                    <TextBlock Text="{Binding Id}"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" MinHeight="150" Margin="10">
                    <TextBlock Text="Nom" FontSize="14"/>
                    <TextBox Text="{Binding Nom}" Width="Auto" MinWidth="150" FontSize="20" Margin="0,5"/>

                    <TextBlock Text="Description" FontSize="14"/>
                    <TextBox Text="{Binding Description}" Width="Auto" MinWidth="150" FontSize="20" Margin="0,5"/>

                    <TextBlock Text="Statut" FontSize="14"/>
                    <ComboBox SelectedItem="{Binding Statut}" ItemsSource="{Binding LesStatutAbris}" 
                          Width="Auto" MinWidth="150" FontSize="20" Margin="0,5" Padding="5,0"/>

                </StackPanel>

                <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Height="Auto" Width="Auto">
                    <Button Content="Nouveau"
                        Command="{Binding NouveauCommand}"
                        Width="100"
                        Height="35"
                        Margin="10"/>

                    <Button Content="Enregistrer"
                        Command="{Binding AjouteCommand}"
                        Width="100"
                        Height="35"
                        Margin="10"/>

                    <Button Content="Supprimer"
                        Command="{Binding SupprimerCommand}"
                        Width="100"
                        Height="35"
                        Margin="10"/>
                </StackPanel>

            </StackPanel>

        </StackPanel>



    </Grid>
</UserControl>
