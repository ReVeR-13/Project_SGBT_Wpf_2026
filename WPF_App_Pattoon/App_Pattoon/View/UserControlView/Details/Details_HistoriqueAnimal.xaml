<UserControl x:Class="Wpf_App_Pattoon_Animalerie.View.UserControlView.Details.Details_HistoriqueAnimal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf_App_Pattoon_Animalerie.View.UserControlView.Details"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="61*"/>
            <RowDefinition Height="329*"/>
            <RowDefinition Height="60*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock TextWrapping="Wrap" Text="HISTORIQUE ANIMAL"
                       FontSize="16" HorizontalAlignment="Center"/>
            <TextBlock TextWrapping="Wrap" Text="{Binding Title}"
                        FontSize="20" HorizontalAlignment="Center" Foreground="#FFEC9700"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Background="#FFFFE291">
            <TextBlock TextWrapping="Wrap" Text="{Binding Title2}"
                        FontSize="16" HorizontalAlignment="Center"/>
            <DataGrid Height="100" ItemsSource="{Binding HistoriqueSources}" Background="{x:Null}"/>

        </StackPanel>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Demandes" 
                    Command="{Binding DemandeCommand}" 
                    FontSize="16"
                    Height="30" Width="100"
                    Margin="5"
                    Background="#FFFFFFE7" Foreground="#FF118BCA" 
                    BorderBrush="#FFFFE66F"/>
            <Button Content="Entrees" 
                    Command="{Binding EntreeCommand}" 
                    FontSize="16"
                    Height="30" Width="100"
                    Margin="5"
                    Background="#FFFFFFE7" Foreground="#FF118BCA" 
                    BorderBrush="#FFFFE66F"/>
            <Button Content="Sorties" 
                    Command="{Binding SortieCommand}" 
                    FontSize="16"
                    Height="30" Width="100"
                    Margin="5"
                    Background="#FFFFFFE7" Foreground="#FF118BCA" 
                    BorderBrush="#FFFFE66F"/>
            <Button Content="Adoptions" 
                    Command="{Binding AdoptionCommand}" 
                    FontSize="16"
                    Height="30" Width="100"
                    Margin="5"
                    Background="#FFFFFFE7" Foreground="#FF118BCA" 
                    BorderBrush="#FFFFE66F"/>
            <Button Content="Accueils" 
                    Command="{Binding AccueilCommand}" 
                    FontSize="16"
                    Height="30" Width="100"
                    Margin="5"
                    Background="#FFFFFFE7" Foreground="#FF118BCA" 
                    BorderBrush="#FFFFE66F"/>
        </StackPanel>

    </Grid>
</UserControl>
