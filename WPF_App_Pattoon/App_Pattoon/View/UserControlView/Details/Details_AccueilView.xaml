<UserControl x:Class="Wpf_App_Pattoon_Animalerie.View.UserControlView.Details.Details_AccueilView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf_App_Pattoon_Animalerie.View.UserControlView.Details"
             xmlns:src="clr-namespace:Wpf_App_Pattoon_Animalerie.Modele"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1000">
    <UserControl.Resources>
        <src:EnumToBoolConverter x:Key="EnumToBool"/>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="11*"/>
            <RowDefinition Height="79*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical">
            <TextBlock TextWrapping="Wrap" Text="{Binding Title}" 
                   HorizontalAlignment="Center" FontSize="20"/>
            <TextBlock TextWrapping="Wrap" Text="{Binding Message}" 
                   HorizontalAlignment="Center" FontSize="14" Foreground="Red"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="49*"/>
                <ColumnDefinition Width="31*"/>
            </Grid.ColumnDefinitions>



            <StackPanel Grid.Column="0" Margin="10">

                <StackPanel  Height="30" Background="#FF8DD8FF">
                    <TextBlock TextWrapping="Wrap" Text="{Binding InfoEtape}" 
                           HorizontalAlignment="Center" 
                           FontSize="20" Foreground="#FF0C2E4E"/>
                </StackPanel>

                <GroupBox Height="Auto" Header="Choix de la Demande">
                    <DataGrid ItemsSource="{Binding LesDemandes}"
                          SelectedItem="{Binding DemandeSelectionne}"
                          SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True"
                          />
                </GroupBox>

                <GroupBox Height="100" Header="Details">
                    <TextBox TextWrapping="Wrap" Text="{Binding Infos}" Foreground="#FF0076E4" Background="White" BorderBrush="#FFBECEFF"/>
                </GroupBox>

                <GroupBox Height="100" Header="Decision">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Text="Votre Decision actuel"/>
                        <StackPanel >
                            <RadioButton GroupName="decision" Content="Accepter"
                                     IsChecked="{Binding StatutSelectionne,
                            Converter={StaticResource EnumToBool},
                            ConverterParameter={x:Static src:EStatutValidation.ACCEPTEE}}" Foreground="#FF0693FF"/>
                            <RadioButton GroupName="decision" Content="Refuser"
                                     IsChecked="{Binding StatutSelectionne,
                            Converter={StaticResource EnumToBool},
                            ConverterParameter={x:Static src:EStatutValidation.REFUSEE}}" Background="{x:Null}" Foreground="#FF0693FF"/>
                            <RadioButton GroupName="decision" Content="Indecis"
                                     IsChecked="{Binding StatutSelectionne,
                            Converter={StaticResource EnumToBool},
                            ConverterParameter={x:Static src:EStatutValidation.EN_COURS}}" Foreground="#FF0693FF"/>
                        </StackPanel>

                    </StackPanel>

                </GroupBox>

                <GroupBox Height="100" Header="Raison de refus">
                    <TextBox TextWrapping="Wrap" Text="{Binding RaisonRefus}" 
                         Background="#FFF9F9F9" Foreground="#FF07559E"/>
                </GroupBox>

            </StackPanel>

            <StackPanel Grid.Column="1">
                <GroupBox  Header="Identité" MinHeight="110" Padding="10" Foreground="#FFFF7500" BorderBrush="#FFEDEDED">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Text="{Binding DemandeSelectionne.Statut}"/>
                        <TextBlock TextWrapping="Wrap" Text="{Binding Id}"/>
                        <TextBlock TextWrapping="Wrap" Text="{Binding DemandeSelectionne.Id}"/>
                        <TextBlock TextWrapping="Wrap" Text="{Binding DateCreation}"/>
                    </StackPanel>
                </GroupBox>

                <TextBlock TextWrapping="Wrap" 
                       Text="Les infos de le demande"
                       HorizontalAlignment="Center"
                       Padding="10,3"
                       Margin="0,15,0,1"
                       FontWeight="Bold" 
                       Background="#FFFFF7CF" 
                       Foreground="#FF0C566F"/>

                <GroupBox Header="Info du Contact" MinHeight="110" Padding="10" Foreground="DarkOrange">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Text="{Binding DemandeSelectionne.Contact.Id}"/>
                        <TextBlock TextWrapping="Wrap" Text="{Binding DemandeSelectionne.Contact.Nom}"/>
                        <TextBlock TextWrapping="Wrap" Text="{Binding DemandeSelectionne.Contact.Gsm}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Info de l' Animal" MinHeight="110" Padding="10" Foreground="DarkOrange">
                    <StackPanel >
                        <TextBlock TextWrapping="Wrap" Text="{Binding DemandeSelectionne.Animal.Id}"/>
                        <TextBlock TextWrapping="Wrap" Text="{Binding DemandeSelectionne.Animal.Nom}"/>
                        <TextBlock TextWrapping="Wrap" Text="{Binding DemandeSelectionne.Animal.Sexe}"/>
                    </StackPanel>
                </GroupBox>

                <TextBlock TextWrapping="Wrap" 
                       Text="Les infos de l'Accueil"
                       HorizontalAlignment="Center"
                       Padding="10,3"
                       Margin="0,15,0,1"
                       FontWeight="Bold" 
                       Background="#FFFFF7CF" 
                       Foreground="#FF0C566F"/>

                <GroupBox Header="Decision" MinHeight="110" Padding="10" Foreground="DarkOrange">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Text="{Binding StatutSelectionne}"/>
                        <TextBlock TextWrapping="Wrap" Text="{Binding DateF}"/>
                        <TextBlock TextWrapping="Wrap" Text="{Binding RaisonRefus}"/>
                    </StackPanel>
                </GroupBox>


                <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <Button Content="Nouveau" 
                        Command="{Binding NouveauCommande}" 
                        FontSize="16"
                        Height="30" Width="80"
                        Margin="5"
                        Background="#FFFFFFE7" Foreground="#FF118BCA" 
                        BorderBrush="#FFFFE66F"/>

                    <Button Content="Enregistrer" 
                        Command="{Binding EnregistreCommande}" 
                        FontSize="16"
                        Height="30" Width="80"
                        Margin="5"
                        Background="#FFFFFFE7" Foreground="#FF118BCA" 
                        BorderBrush="#FFFFE66F"/>

                    <Button Content="Supprimer" 
                        Command="{Binding DeleteCommande}" 
                        FontSize="16"
                        Height="30" Width="80"
                        Margin="5"
                        Background="#FFFFFFE7" Foreground="#FF118BCA" 
                        BorderBrush="#FFFFE66F"/>

                    <Button Content="Sortie" 
                        Command="{Binding VersSortieCommande}" 
                        FontSize="16"
                        Height="30" Width="80"
                        Margin="5"
                        Background="#FFFFFFE7" Foreground="#FF118BCA" 
                        BorderBrush="#FFFFE66F"/>

                </StackPanel>


            </StackPanel>

        </Grid>


    </Grid>
</UserControl>
