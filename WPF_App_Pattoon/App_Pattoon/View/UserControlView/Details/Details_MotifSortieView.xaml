<UserControl x:Class="Wpf_App_Pattoon_Animalerie.View.UserControlView.Details.Details_MotifSortieView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf_App_Pattoon_Animalerie.View.UserControlView.Details"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White" Width="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="11*"/>
            <RowDefinition Height="66*"/>
            <RowDefinition Height="13*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock TextWrapping="Wrap" Text="{Binding Title}" FontSize="18"/>
            <TextBlock TextWrapping="Wrap" Text="{Binding  Message}" FontSize="14"/>
        </StackPanel>

        <Border BorderBrush="#FFFF843D" BorderThickness="1" Height="1" Width="360" Background="#FFF1763B" VerticalAlignment="Bottom"/>

        <StackPanel Grid.Row="1" Background="White" Margin="10">
            <Label Content="Nom"/>
            <TextBox TextWrapping="Wrap" Text="{Binding Nom}" Padding="5" Margin="5,0" Foreground="#FF144E73" Background="#FFF1F1F1" BorderBrush="{x:Null}"/>

            <Label Content="Description"/>
            <RichTextBox Height="100" Padding="5" Margin="5,0" Background="#FFF3F3F3" Foreground="#FF0D486D" BorderBrush="{x:Null}">
                <FlowDocument>
                    <Paragraph FontSize="14" >
                        <Run Text="{Binding Description}"/>
                    </Paragraph>
                </FlowDocument>
            </RichTextBox>

        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#FFFF843D" BorderThickness="1" Height="1" Width="360" Background="#FFF1763B" VerticalAlignment="Bottom"/>

        <StackPanel Grid.Row="2" 
    Orientation="Horizontal" 
    HorizontalAlignment="Center" 
    VerticalAlignment="Center" Height="40" Width="330">

            <Button Content="Annuler" 
    Command="{Binding NouveauCommand}" 
    FontSize="16"
    Height="30" Width="100"
    Margin="5"
    Background="#FFFFFFE7" Foreground="#FF118BCA" 
    BorderBrush="#FFFFE66F"/>

            <Button Content="Enregistrer" 
    Command="{Binding AjouteCommand}" 
    FontSize="16"
    Height="30" Width="100"
    Margin="5"
    Background="#FFECFFE7" Foreground="#FF11CA25" BorderBrush="#FF6FFF71"/>

            <Button Content="Supprimer" 
    Command="{Binding SupprimerCommand}" 
    FontSize="16"
    Height="30" Width="100"
    Margin="5"
    Background="#FFFFE7E7" Foreground="#FFCA1111" BorderBrush="#FFFF6F6F"/>

        </StackPanel>


    </Grid>
</UserControl>
