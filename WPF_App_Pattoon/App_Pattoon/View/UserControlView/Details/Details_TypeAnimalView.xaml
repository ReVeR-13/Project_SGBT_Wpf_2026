<UserControl x:Class="Wpf_App_Pattoon_Animalerie.View.UserControlView.Details.Details_TypeAnimalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf_App_Pattoon_Animalerie.View.UserControlView.Details"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="11*"/>
            <RowDefinition Height="62*"/>
            <RowDefinition Height="17*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center">
            <TextBlock TextWrapping="Wrap" Text="{Binding Title}"
                   FontSize="18"/>
            <TextBlock TextWrapping="Wrap" Text="{Binding Message}"
                   FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Width="400">

            <GroupBox Height="50" Header="Nom" BorderBrush="{x:Null}" Foreground="#FFFF5D00">
                <TextBox TextWrapping="Wrap" Text="{Binding Nom}" 
                     FontSize="16"
                     Background="#FFFFFDE6" 
                     Foreground="#FF006F84" 
                     BorderBrush="{x:Null}" />
            </GroupBox>

            <GroupBox Height="100" Header="Description" BorderBrush="{x:Null}" Foreground="#FFFF5D00">
                <TextBox TextWrapping="Wrap" 
                     Text="{Binding Description}"
                     FontSize="16"
                     Background="#FFFFFDE6" 
                     BorderBrush="{x:Null}" 
                     Foreground="#FF05769C" />
            </GroupBox>

        </StackPanel>

        <StackPanel  Grid.Row ="2" Orientation="Horizontal" HorizontalAlignment="Center" Width="450">

            <Button Content="Annuler" 
        Command="{Binding NouveauCommand}" 
        FontSize="16"
        Width="130"
        Height="30" 
        Margin="10"
        Background="#FFFFFFE7" Foreground="#FF118BCA" BorderBrush="#FFFFE66F"/>

            <Button Content="Enregistrer" 
        Command="{Binding AjouteCommand}" 
                FontSize="16"
                Width="130"
                Height="30" 
                Margin="10"
                Background="#FFD1FFCB" Foreground="#FF2D889A" BorderBrush="#FFA0FF00"/>

            <Button Content="Supprimer" 
        Command="{Binding SupprimerCommand}" 
                FontSize="16"
                Width="130"
                Height="30"  
                Margin="10"
                Background="#FFFFCDCD" Foreground="#FF1591B1" BorderBrush="#FFD61818"/>
        </StackPanel>

    </Grid>
</UserControl>
