<UserControl x:Class="Wpf_App_Pattoon_Animalerie.View.UserControlView.Details.Details_ContactView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf_App_Pattoon_Animalerie.View.UserControlView.Details"
             mc:Ignorable="d" 
             MinHeight="660" MinWidth="1250">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="17*"/>
            <RowDefinition Height="115*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="Auto">

            <TextBlock Grid.Row="0" TextWrapping="Wrap" 
                        Text="{Binding Id}" 
                        Width="200" FontSize="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment ="Center"/>

            <TextBlock Grid.Row="0" TextWrapping="Wrap" 
                       Text="{Binding Message}" 
                       Width="Auto" FontSize="10"
                       HorizontalAlignment="Center"
                       VerticalAlignment ="Center" Foreground="#FFC70E0E"/>

        </StackPanel>
        

        <Grid Grid.Row="1" Margin="0,0,4,0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>


            <Grid Grid.Column="0" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20*"/>
                    <RowDefinition Height="17*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="425*"/>
                        <ColumnDefinition Width="451*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">

                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,10,10,10">

                        <Label Content="Nom" Foreground="#FFE27315"/>
                        <TextBox TextWrapping="Wrap" Text="{Binding Nom}" 
                         Grid.Column="1" Height="40"  
                         Padding="10,5" FontSize="18"
                         BorderBrush="{x:Null}" 
                         Foreground="#FF097286" 
                         Background="#FFF7F7F7"
                         SelectionTextBrush="#FFFFFCB9" 
                         SelectionBrush="#FFFFF614"/>

                        <Label Content="Prenom" Margin="0,10,0,0" Foreground="#FFE27315"/>
                        <TextBox TextWrapping="Wrap" Text="{Binding Prenom}" 
                         Grid.Column="1" Height="40"  
                         Padding="10,5" FontSize="18"
                         BorderBrush="{x:Null}" 
                         Foreground="#FF097286" 
                         Background="#FFF7F7F7" 
                         SelectionTextBrush="#FFFFFCB9" 
                         SelectionBrush="#FFFFF614"/>

                        <Label Content="Niss" Margin="0,10,0,0" Foreground="#FFE27315"/>
                        <TextBox TextWrapping="Wrap" Text="{Binding Niss}" 
                         Grid.Column="1" Height="40"  
                         Padding="10,5" FontSize="18"
                         BorderBrush="{x:Null}" 
                         Foreground="#FF097286" 
                         Background="#FFF7F7F7" 
                         SelectionTextBrush="#FFFFFCB9" 
                         SelectionBrush="#FFFFF614"/>

                        <Label Content="Date de naissance" Margin="0,10,0,0" Foreground="#FFE27315"/>
                        <DatePicker Grid.Column="1" Height="40"  
                                    Padding="10,4" FontSize="18"
                                    Text="{Binding DateNaissance}"
                                    BorderBrush="{x:Null}" 
                                    Foreground="#FF02334C" 
                                    Background="#FFF7F7F7"/>




                    </StackPanel>


                </Grid>

                <Grid Grid.Row="1" Background="#FFF3F3F3">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="275*"/>
                        <ColumnDefinition Width="365*"/>
                        <ColumnDefinition Width="236*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock TextWrapping="Wrap" Text="CONTACT" Margin="0,0,0,10"/>

                        <Label Content="Gsm" Margin="0,10,0,0" Foreground="#FFE27315"/>
                        <TextBox TextWrapping="Wrap" Text="{Binding Gsm}" 
                         Grid.Column="1" Height="40"  
                         Padding="10,5" FontSize="18"
                         BorderBrush="{x:Null}" 
                         Background="#FFEBEBEB" 
                         SelectionTextBrush="#FFFFFCB9" 
                         SelectionBrush="#FFFFF614" Foreground="#FF097286"/>

                        <Label Content="Telephone" Margin="0,10,0,0" Foreground="#FFE27315"/>
                        <TextBox TextWrapping="Wrap" Text="{Binding Telephone}" 
                         Grid.Column="1" Height="40"  
                         Padding="10,5" FontSize="18"
                         BorderBrush="{x:Null}" 
                         Background="#B2E8E8E8" 
                         SelectionTextBrush="#FFFFFCB9" 
                         SelectionBrush="#FFFFF614" Foreground="#FF097286"/>

                        <Label Content="e-mail" Margin="0,10,0,0" Foreground="#FFE27315"/>
                        <TextBox TextWrapping="Wrap" Text="{Binding Mail}" 
                         Grid.Column="1" Height="40"  
                         Padding="10,5" FontSize="18"
                         BorderBrush="{x:Null}" 
                         Background="#B2E8E8E8" 
                         SelectionTextBrush="#FFFFFCB9" 
                         SelectionBrush="#FFFFF614" Foreground="#FF097286"/>

                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10,0">

                        <TextBlock TextWrapping="Wrap" Text="ADRESSE" Margin="0,0,0,10"/>

                        <Label Content="Code Postale" Margin="0,10,0,0" Foreground="#FFE27315"/>
                        <TextBox TextWrapping="Wrap" Text="{Binding CodePostal}" 
                         Grid.Column="1" Height="40"  
                         Padding="10,5" FontSize="18"
                         BorderBrush="{x:Null}" 
                         Background="#B2E8E8E8" 
                         SelectionTextBrush="#FFFFFCB9" 
                         SelectionBrush="#FFFFF614" Foreground="#FF097286"/>

                        <Label Content="Localite" Margin="0,10,0,0" Foreground="#FFE27315"/>
                        <TextBox TextWrapping="Wrap" Text="{Binding Localite}" 
                         Grid.Column="1" Height="40"  
                         Padding="10,5" FontSize="18"
                         BorderBrush="{x:Null}" 
                         Background="#B2E8E8E8" 
                         SelectionTextBrush="#FFFFFCB9" 
                         SelectionBrush="#FFFFF614" Foreground="#FF097286"/>

                        <Label Content="Rue" Margin="0,10,0,0" Foreground="#FFE27315"/>
                        <TextBox TextWrapping="Wrap" Text="{Binding Adresse}" 
                         Grid.Column="1" Height="40"  
                         Padding="10,5" FontSize="18"
                         BorderBrush="{x:Null}" 
                         Background="#B2E8E8E8" 
                         SelectionTextBrush="#FFFFFCB9" 
                         SelectionBrush="#FFFFF614" Foreground="#FF097286"/>


                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="10,0">

                        <TextBlock TextWrapping="Wrap" Text="INFOS" Margin="0,0,0,10"/>

                        <Label Content="Roles" Margin="0,10,0,0" Foreground="#FFE27315"/>
                        <ListBox Height="132" ItemsSource="{Binding MesRoles}" 
                         Background="#FF0DAFDA" 
                         BorderBrush="{x:Null}" 
                         Foreground="White" 
                         FontSize="16"/>

                        <Button Content="Add Role" Margin="0,10"
                        Command="{Binding AddRoleCommand}"
                        Grid.Column="1" Height="34"  
                        Padding="10,5" FontSize="16"
                        Foreground="#FFFFBE0B" Background="#FF83836F" BorderBrush="#FFFFBE0B"/>


                    </StackPanel>

                </Grid>

            </Grid>

            <StackPanel Grid.Column="1" Width="Auto" Height="Auto" 
                        MinWidth="20" MinHeight="20"
                        Margin="10,10,10,10" Grid.RowSpan="2">

                <StackPanel Margin="0,40">

                    <Button Content="Voir les roles" 
                            Command="{Binding AfficherVaccinsCommand}" 
                            FontSize="16"
                            Height="40" Margin="10" 
                            Background="#FFFFDE78" Foreground="#FF2D889A" BorderBrush="{x:Null}"/>

                </StackPanel>


                <StackPanel Margin="0,30">
                    <Button Content="Annuler" 
                            Command="{Binding AfficherVaccinsCommand}" 
                            FontSize="16"
                            Height="40" 
                            Margin="10"
                            Background="#FFFFFFE7" Foreground="#FF118BCA" BorderBrush="#FFFFE66F"/>

                    <Button Content="Enregistrer" 
                            Command="{Binding AfficherVaccinsCommand}" 
                            FontSize="16"
                            Height="40"  Margin="10"
                            Background="#FFD1FFCB" Foreground="#FF2D889A" BorderBrush="#FFA0FF00"/>

                    <Button Content="Supprimer" 
                            Command="{Binding AfficherVaccinsCommand}" 
                            FontSize="16"
                            Height="40" 
                            Margin="10"
                            Background="#FFFFCDCD" Foreground="#FF1591B1" BorderBrush="#FFD61818"/>
                </StackPanel>
            </StackPanel>

        </Grid>

    </Grid>
</UserControl>
